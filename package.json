{
  "name": "details-markdown",
  "version": "0.1.1",
  "description": "Obsidian plugin: render Markdown inside native HTML details blocks in Reading view.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "details",
    "markdown"
  ],
  "author": "Nickolay Kondratyev",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "happy-dom": "^20.11.1",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
